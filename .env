# Application
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://w4agent:w4agent_pass@localhost:5432/w4agent

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-9eba1adb38fa4cb1af5dca05f58f8472
OPENAI_BASE_URL=http://routify.alibaba-inc.com/protocol/openai/v1
OPENAI_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=sk-9eba1adb38fa4cb1af5dca05f58f8472
ANTHROPIC_BASE_URL=https://routify.alibaba-inc.com/protocol/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Playwright
BROWSER_POOL_SIZE=3
PAGE_TIMEOUT_MS=30000
# SCREENSHOT_DIR defaults to backend/screenshots (absolute path)
# Only set this if you need a custom location:
# SCREENSHOT_DIR=/absolute/path/to/screenshots

# Jira Integration
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
